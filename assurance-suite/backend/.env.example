# Copy this file to .env and fill in real values.

PORT=4000

# Allow your frontend's origin (Vite dev server default shown below).
# Use "*" only for local development.
CORS_ORIGIN=http://localhost:5173

# Required for the AI evidence assistant (Evidence -> "Ask AI about this file").
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5 if not set.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — where the SQLite file is written. Defaults to backend/assurance-suite.db
DB_PATH=./assurance-suite.db
